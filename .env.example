# Public app / brand
NEXT_PUBLIC_APP_NAME=Amém Chat
NEXT_PUBLIC_APP_TAGLINE=Como Jesus responderia à sua situação?
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=amemchatbr@gmail.com
NEXT_PUBLIC_LEGAL_ENTITY_NAME=
NEXT_PUBLIC_LEGAL_ENTITY_DOCUMENT=
NEXT_PUBLIC_TERMS_VERSION=2026-07-12
NEXT_PUBLIC_PRIVACY_VERSION=2026-07-12
NEXT_PUBLIC_INSTAGRAM_HANDLE=

# Public Supabase (safe for browser) — prefer publishable key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Temporary compatibility (prefer PUBLISHABLE_KEY above)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret — never expose to the client. Not required for normal user flows.
SUPABASE_SECRET_KEY=
# Temporary compatibility (prefer SUPABASE_SECRET_KEY above)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — server-only. Required in production/preview (unless DEMO_MODE=true on preview).
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4.1-mini
OPENAI_MODEL_DEEP=gpt-4.1

# Runtime
APP_URL=http://localhost:3000
# Preview only: allow mocks when true. Ignored/forbidden semantics in production.
DEMO_MODE=

# Planning FX rate for cost estimates (USD → BRL). Not a live market feed.
USD_BRL_PLANNING_RATE=5.50

# Stripe — server-only. Sandbox/test keys for development.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENCIAL=
STRIPE_PRICE_CAMINHO=
STRIPE_PRICE_PROFUNDO=
