# Public Supabase (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the client. Not required for normal user flows.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — server-only. If absent, MockAiProvider is used.
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4.1-mini
OPENAI_MODEL_DEEP=gpt-4.1

# App
APP_URL=http://localhost:3000

# Planning FX rate for cost estimates (USD → BRL). Not a live market feed.
USD_BRL_PLANNING_RATE=5.50
